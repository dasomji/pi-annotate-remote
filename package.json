{
  "name": "pi-annotate",
  "version": "0.4.3",
  "description": "Visual annotation tool for Pi coding agent with inline note cards",
  "type": "module",
  "author": "Nico Bailon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dasomji/pi-annotate-remote.git"
  },
  "bugs": {
    "url": "https://github.com/dasomji/pi-annotate-remote/issues"
  },
  "homepage": "https://github.com/dasomji/pi-annotate-remote#readme",
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "node --check index.ts && node --check broker/*.js && node --check chrome-extension/*.js"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
